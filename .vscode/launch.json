{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "interface": "swd",
            "cwd": "${workspaceFolder}",
            "executable": "${command:cmake.launchTargetPath}",
            "device": "STM32L476RGT",
            "svdFile": "/opt/STM32CubeProgrammer/SVD/STM32L476.svd",
            "gdbPath": "/usr/bin/arm-none-eabi-gdb",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32l4x.cfg"
            ],
            "openOCDLaunchCommands": [
                "program ${command:cmake.launchTargetPath} verify reset",
            ],
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 3
            },
            "objdumpPath": "/usr/bin/arm-none-eabi-objdump",
            "preLaunchTask": "CMake: build"
        },
        {
            "name": "Attach",
            "type": "cortex-debug",
            "request": "attach",
            "servertype": "openocd",
            "interface": "swd",
            "cwd": "${workspaceFolder}",
            "executable": "${command:cmake.launchTargetPath}",
            "device": "STM32L476RGT",
            "svdFile": "/opt/STM32CubeProgrammer/SVD/STM32L476.svd",
            "gdbPath": "/usr/bin/arm-none-eabi-gdb",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32l4x.cfg"
            ],
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 3
            },
            "objdumpPath": "/usr/bin/arm-none-eabi-objdump"
        }
    ]
}
